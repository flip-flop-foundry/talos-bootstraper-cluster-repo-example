{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Render Overlay",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/adminTasks/render-overlay.sh \"${input:envFile}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Apply Overlay",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/adminTasks/cluster-bootstrap.sh \"${input:envFile}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Render and Push to Gitea",
      "dependsOn": ["Render Overlay"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/adminTasks/push-to-gitea.sh \"${input:envFile}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Apply Talos configs",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/adminTasks/cluster-initialSetup.sh \"${input:envFile}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Set Active Talos/Kube Context",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/.vscode/tasks/set-active-talos-kube-context.sh \"${input:envFile}\" \"${workspaceFolder}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Reset Talos Node System Volumes",
      "type": "shell",
      "command": "mkdir -p \"${workspaceFolder}/.vscode/current\" && echo -n \"${input:envFile}\" > \"${workspaceFolder}/.vscode/current/selected-env\" && ${workspaceFolder}/talos-bootstraper/.vscode/tasks/reset-talos-nodes.sh \"${input:envFile}\"",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "envFile",
      "type": "command",
      "command": "shellCommand.execute",
      "args": {
        "command": "find overlays -maxdepth 2 -name '*.env' | sort",
        "cwd": "${workspaceFolder}",
        "description": "Select the overlay env file to use. The first one will be used when setting up tools in devcontainer",
        "rememberPrevious": true,
        "rememberAs": "envFile"
      }
    }
  ]
}
