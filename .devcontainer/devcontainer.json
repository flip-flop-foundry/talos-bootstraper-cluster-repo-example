{
  "name": "Tuborgnetes",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "timonwong.shellcheck",
        "mads-hartmann.bash-ide-vscode",
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "augustocdias.tasks-shell-input"
      ]
    }
  },
  "initializeCommand": "mkdir -p ~/.copilot",
  "mounts": [
    "source=${localEnv:HOME}/.copilot,target=/home/vscode/.copilot,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "KUBECONFIG": "${containerWorkspaceFolder}/.vscode/current/kubeconfig",
    "TALOSCONFIG": "${containerWorkspaceFolder}/.vscode/current/talosconfig"
  },
  "remoteUser": "vscode",
  "postCreateCommand": ".devcontainer/install-tools.sh ${containerWorkspaceFolder}",
  "postStartCommand": "grep -q 'envoke shell-init' ~/.zshrc 2>/dev/null || echo 'eval \"$(envoke shell-init)\"' >> ~/.zshrc"
}
